# ============================================================
#  PRODUCTION — augustinidohou.site
#  Copier en `.env` à la racine du projet sur le serveur :
#     cp deploy/env.production.example .env
#  puis remplir les valeurs. Ne JAMAIS committer le vrai .env.
# ============================================================

# --- Django ---
# Génère une clé : python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGE_MOI_cle_longue_et_aleatoire
DEBUG=False
ALLOWED_HOSTS=augustinidohou.site,www.augustinidohou.site
CSRF_TRUSTED_ORIGINS=https://augustinidohou.site,https://www.augustinidohou.site

# Le TLS est terminé par le Nginx de l'hôte → on garde la redirection SSL active.
SECURE_SSL_REDIRECT=True

# --- Base de données PostgreSQL (service "db" du docker-compose) ---
POSTGRES_DB=augustinidohou
POSTGRES_USER=augustin
POSTGRES_PASSWORD=CHANGE_MOI_mot_de_passe_db_solide
DATABASE_URL=postgres://augustin:CHANGE_MOI_mot_de_passe_db_solide@db:5432/augustinidohou

# --- Contenu / e-mail ---
CONTACT_EMAIL=asidev7@gmail.com
DEFAULT_FROM_EMAIL=contact@augustinidohou.site
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# Mettre à true UNIQUEMENT pour la toute première mise en ligne
# (peuple projets, skills, blog, CV...). Repasser à false ensuite.
SEED_ON_START=true

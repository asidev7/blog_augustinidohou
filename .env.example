# ============================================================
#  Variables d'environnement — PORTFOLIO Augustin Sande Idohou
#  Copier en `.env` (en local ou sur le serveur) et remplir.
#  Ne JAMAIS committer le vrai .env (voir .gitignore).
# ============================================================

# Génère une clé : python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=remplace-moi-par-une-cle-secrete-longue-et-aleatoire

# IMPÉRATIF en production
DEBUG=False

# Domaine(s) et IP du serveur, séparés par des virgules
ALLOWED_HOSTS=augustinidohou.site,www.augustinidohou.site,VOTRE_IP

# Origines de confiance pour le CSRF (avec le schéma https://)
CSRF_TRUSTED_ORIGINS=https://augustinidohou.site,https://www.augustinidohou.site

# Base de données : SQLite par défaut si non défini.
# PostgreSQL en prod : postgres://user:motdepasse@hote:port/nom_base
# DATABASE_URL=postgres://augustin:MOT_DE_PASSE_DB@127.0.0.1:5432/augustinidohou

# Mettre False seulement si le HTTPS n'est pas encore configuré
SECURE_SSL_REDIRECT=True

# E-mail (laisser console tant que rien n'est configuré)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=contact@augustinidohou.site
# Adresse qui reçoit les messages du formulaire de contact
CONTACT_EMAIL=contact@augustinidohou.site
